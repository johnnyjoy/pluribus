# Copy to .env or pass: docker compose -f docker-compose.install.yml --env-file pluribus.install.env.example up -d
#
# Image is built by CI and pushed to GHCR as ghcr.io/<github-username-lowercase>/pluribus:<tag>
# Tags: branch name (main), sha-*, v* semver + latest — see docs/pluribus-image-release-policy.md
#
# Local image (same compose file): from repo root run `make image`, then point at the tagged image, e.g.:
#   PLURIBUS_IMAGE=pluribus:local
#   PLURIBUS_IMAGE=pluribus:$(git describe --tags --always --dirty)

PLURIBUS_IMAGE=ghcr.io/your-github-username/pluribus:main

# Optional: require X-API-Key on the control-plane HTTP API (omit for open installs).
# PLURIBUS_API_KEY=sk-...
