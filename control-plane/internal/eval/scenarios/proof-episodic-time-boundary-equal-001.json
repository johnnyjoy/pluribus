{
  "id": "proof-episodic-time-boundary-equal-001",
  "suite": "episodic",
  "description": "Equal occurred_after and occurred_before (single instant) includes episodes whose effective time matches that instant.",
  "steps": [
    {
      "id": "ingest_at_instant",
      "method": "POST",
      "path": "/v1/advisory-episodes",
      "body": {
        "summary": "TIME EQUAL BOUND MARKER {{RUN_ID}} kafka consumer lag spike error during deploy freeze window",
        "source": "manual",
        "tags": ["proof:episodic:teq:{{RUN_ID}}"],
        "occurred_at": "2018-05-20T12:30:00Z",
        "entities": ["kafka"]
      },
      "expect_status": 201
    },
    {
      "id": "similar_same_instant_bounds",
      "method": "POST",
      "path": "/v1/advisory-episodes/similar",
      "body": {
        "query": "time equal bound marker kafka consumer lag",
        "tags": ["proof:episodic:teq:{{RUN_ID}}"],
        "occurred_after": "2018-05-20T12:30:00Z",
        "occurred_before": "2018-05-20T12:30:00Z",
        "entities": ["kafka"],
        "max_results": 5
      },
      "expect_status": 200,
      "asserts": [
        {"kind": "body_contains", "value": "TIME EQUAL BOUND MARKER"}
      ]
    }
  ]
}
