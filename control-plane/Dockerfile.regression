# One-shot test image: run control-plane unit + integration tests against a linked Postgres (compose).
# Build context: repository root (must include docs/ for guardrails Recall repo root detection).
FROM golang:1.22-bookworm
WORKDIR /work
ENV CGO_ENABLED=0
COPY control-plane/go.mod control-plane/go.sum ./control-plane/
RUN cd control-plane && go mod download
COPY control-plane/ ./control-plane/
COPY docs/ ./docs/
COPY README.md CONTRIBUTING.md ./
WORKDIR /work/control-plane
# -tags=integration compiles integration tests in cmd/controlplane; other packages unchanged.
# -count=1 avoids cache surprises; -p=1 serializes packages sharing one TEST_PG_DSN.
CMD ["go", "test", "-tags=integration", "-count=1", "-p", "1", "./..."]
